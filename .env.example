# Qwen Cloud pay-as-you-go keys use the default URL below.
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_PRIMARY_MODEL=qwen3.7-plus
QWEN_CRITIC_MODEL=qwen3.6-flash

# Generate at least 32 random bytes for deployed environments.
APPROVAL_HMAC_SECRET=replace-with-a-long-random-secret
ALLOWED_ORIGIN=http://localhost:5173
PORT=9000

# Used only by scripts/generate-demo-tts.ts.
OPENAI_API_KEY=
